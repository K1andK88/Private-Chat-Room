VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: set a password to gate access to the site
# VITE_ACCESS_PASSWORD=your_access_password_here

# Optional: message expiration time in minutes (default: 10)
# VITE_MESSAGE_TTL=10

# Optional: custom verify secret for room password validation (default: PCR_VERIFY_2026)
# VITE_VERIFY_SECRET=your_custom_secret
